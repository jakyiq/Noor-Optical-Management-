{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    },
    {
      "src": "localFirst.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/sw.js",
      "dest": "sw.js"
    },
    {
      "src": "/localFirst.js",
      "dest": "localFirst.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
